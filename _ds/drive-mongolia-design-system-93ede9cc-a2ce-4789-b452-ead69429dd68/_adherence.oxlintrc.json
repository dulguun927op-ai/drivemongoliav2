{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/fleet/**",
              "ui_kits/marketing/**",
              "uploads/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Oswald|Inter))/i]",
        "message": "Font not provided by the design system. Available: Oswald, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|icon|iconRight|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, icon, iconRight, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|ghostlight|dark)$/]",
        "message": "<Button> variant must be one of 'solid' | 'outline' | 'ghostlight' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Button> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<FeatureTag> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<FilterTab> doesn't accept that prop. Declared props: children, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|as|style|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, tone, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:rust|light|muted)$/]",
        "message": "<Kicker> tone must be one of 'rust' | 'light' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LinkArrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|style|key|ref|className|style|children)$/]",
        "message": "<LinkArrow> doesn't accept that prop. Declared props: children, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:k|v|key|ref|className|style|children)$/]",
        "message": "<SpecItem> doesn't accept that prop. Declared props: k, v."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tone|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Stat> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerrainCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|blurb|img|style|key|ref|className|style|children)$/]",
        "message": "<TerrainCard> doesn't accept that prop. Declared props: name, blurb, img, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VehicleRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|name|specs|price|priceUnit|img|available|availabilityLabel|onClick|style|key|ref|className|style|children)$/]",
        "message": "<VehicleRow> doesn't accept that prop. Declared props: category, name, specs, price, priceUnit, img, available, availabilityLabel, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
